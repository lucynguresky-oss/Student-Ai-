{
  "name": "learnix",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter @learnix/db migrate:dev",
    "db:seed": "pnpm --filter @learnix/db seed",
    "gen:keys": "bash scripts/gen-keys.sh",
    "openapi:export": "pnpm --filter @learnix/api openapi:export"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "dotenv": "^16.4.7"
  }
}
