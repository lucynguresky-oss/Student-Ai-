{
  "expo": {
    "name": "Learnix",
    "slug": "learnix",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "learnix",
    "splash": {
      "backgroundColor": "#0B1020",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.learnix.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1020"
      },
      "package": "com.learnix.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
