# Learnix API - Environment Variables
# Copy to .env.local and fill in values

# Database
DATABASE_URL="postgresql://learnix:learnix_dev_2024@localhost:5433/learnix?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Meilisearch
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="learnix_meili_dev_key"

# JWT
JWT_SECRET="learnix_jwt_dev_secret_change_in_production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=4000
NODE_ENV=development

# Mail (Mailhog for dev)
SMTP_HOST="localhost"
SMTP_PORT=1025

# AI (add keys when ready)
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# Storage (add when ready)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=

# Payments (add when ready)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# STRIPE_SECRET_KEY=
# FLUTTERWAVE_SECRET_KEY=
