# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://learnix:learnix_dev@localhost:5432/learnix

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=v1

# ─── Auth / JWT ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── AI (Addendum G + AI Tutor) ──────────────────────────────
OPENAI_API_KEY=sk-...
# IMPORTANT: model name strings change — verify at https://platform.openai.com/docs/models
AI_MODEL=gpt-4o
AI_EMBED_MODEL=text-embedding-3-small
# Embedding vector dimension — must match AI_EMBED_MODEL (text-embedding-3-small = 1536)
AI_EMBED_DIM=1536

# ─── M-Pesa / Daraja ─────────────────────────────────────────
# Sandbox: DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
# Live:    DARAJA_BASE_URL=https://api.safaricom.co.ke
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=your-consumer-key
DARAJA_CONSUMER_SECRET=your-consumer-secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# CustomerPayBillOnline for Paybill, CustomerBuyGoodsOnline for Till
DARAJA_TX_TYPE=CustomerPayBillOnline
# Must be public HTTPS. In dev, use cloudflared/ngrok:
#   cloudflared tunnel --url http://localhost:4000
MPESA_CALLBACK_URL=https://your-tunnel.trycloudflare.com/v1/payments/mpesa/callback

# ─── PayPal ──────────────────────────────────────────────────
# Sandbox: PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
# Live:    PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your-client-id
PAYPAL_CLIENT_SECRET=your-client-secret
# Webhook ID from the PayPal dashboard (required for signature verification)
PAYPAL_WEBHOOK_ID=your-webhook-id

# ─── Google OAuth (optional) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback

# ─── Redis (optional, for caching / rate limiting) ───────────
REDIS_URL=redis://localhost:6379

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
