# ---- Core ----
NODE_ENV=development
PORT=4000

# ---- Database (use PgBouncer in prod: ?pgbouncer=true&connection_limit=1) ----
DATABASE_URL=postgresql://learnix:learnix_dev@localhost:5432/learnix?schema=public
DATABASE_URL_TEST=postgresql://learnix:learnix_dev@localhost:5432/learnix_test?schema=public
# Optional read replica for read/write split at scale:
# DATABASE_REPLICA_URL=postgresql://learnix:learnix_dev@replica:5432/learnix?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT (RS256) — run scripts/gen-keys.sh to populate ----
JWT_KID=key-dev
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- Crypto ----
PASSWORD_PEPPER=change-me-min-16-chars
TWO_FACTOR_ENC_KEY=base64-encoded-32-byte-key

# ---- Web / cookies ----
WEB_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost
API_BASE_URL=http://localhost:4000

# ---- Providers (GLOBAL defaults) ----
# SMS: 'hybrid' routes African numbers -> Africa's Talking, else Twilio. Or 'twilio' | 'africastalking' | 'mock'
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock          # 'resend' | 'ses' | 'mock'
STORAGE_PROVIDER=mock        # 'r2' | 's3' | 'mock'

# Twilio (global SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                 # a Twilio number or Messaging Service SID (MG...)

# Africa's Talking (cost-aware African SMS in hybrid mode)
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM=Learnix <no-reply@learnix.app>

# Cloudflare R2 / S3 (avatars, media)
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# ---- OAuth (Google implemented; Apple stubbed — set APPLE_CLIENT_ID to enable) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/oauth/google/callback
APPLE_CLIENT_ID=
APPLE_REDIRECT_URI=

# ---- Policy ----
POLICY_VERSION=2026-01-01
